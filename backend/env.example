# =============================================================================
# AUTOMATION PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development                        # development | production | test
PORT=3000                                   # HTTP port the Express server listens on
HOST=0.0.0.0                               # Bind address


# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173          # Used for CORS and OAuth redirect URLs
VITE_API_BASE_URL=http://localhost:3000/api # Axios base URL (consumed by Vite)
VITE_WS_URL=ws://localhost:3000            # Socket.io server URL (consumed by Vite)


# -----------------------------------------------------------------------------
# POSTGRES DATABASE
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=automation_platform
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false                               # Set to true for managed cloud DBs

# Alternatively, supply a full connection string (takes precedence if set)
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/automation_platform


# -----------------------------------------------------------------------------
# REDIS (Queue + Session Cache)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                            # Leave blank if no auth
REDIS_DB=0                                 # Database index (0–15)

# For Redis Sentinel (HA setup in production)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Full Redis URL (overrides individual fields if set)
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# JWT AUTH
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d                          # Access token TTL
JWT_REFRESH_SECRET=another_long_random_string_min_64_chars
JWT_REFRESH_EXPIRES_IN=30d                 # Refresh token TTL


# -----------------------------------------------------------------------------
# ENCRYPTION (AES-256 for stored credentials)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=32_byte_hex_string_exactly_64_hex_chars_here
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000                 # Window in milliseconds (1 min)
RATE_LIMIT_MAX_REQUESTS=100               # Requests per window per IP
AUTH_RATE_LIMIT_MAX=10                     # Stricter limit for /auth/* routes
WEBHOOK_RATE_LIMIT_MAX=500                 # Higher limit for webhook endpoints


# -----------------------------------------------------------------------------
# BULL QUEUE (Workflow Execution)
# -----------------------------------------------------------------------------
QUEUE_CONCURRENCY=5                        # Parallel jobs per worker
QUEUE_MAX_ATTEMPTS=3                       # Retry attempts before dead-letter
QUEUE_BACKOFF_DELAY=5000                   # ms between retries (exponential base)
DEAD_LETTER_QUEUE_ENABLED=true


# -----------------------------------------------------------------------------
# OAUTH — GOOGLE (Gmail, Sheets)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/oauth/google/callback
# Scopes requested during Google OAuth
GOOGLE_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/spreadsheets


# -----------------------------------------------------------------------------
# OAUTH — SLACK
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_CALLBACK_URL=http://localhost:3000/api/oauth/slack/callback
SLACK_SIGNING_SECRET=your_slack_signing_secret  # For webhook signature verification


# -----------------------------------------------------------------------------
# OAUTH — META (WhatsApp / Facebook)
# -----------------------------------------------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_CALLBACK_URL=http://localhost:3000/api/oauth/meta/callback
META_VERIFY_TOKEN=your_webhook_verify_token     # For WhatsApp webhook verification
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_API_VERSION=v19.0


# -----------------------------------------------------------------------------
# OAUTH — GITHUB
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/oauth/github/callback


# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=random_string_for_signature_verification


# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=30000


# -----------------------------------------------------------------------------
# RAZORPAY
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret


# -----------------------------------------------------------------------------
# STRIPE (Billing for your platform's own plans)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_FREE_PLAN_PRICE_ID=price_xxxxx
STRIPE_PRO_PLAN_PRICE_ID=price_xxxxx
STRIPE_ENTERPRISE_PLAN_PRICE_ID=price_xxxxx


# -----------------------------------------------------------------------------
# NOTION (Integration node)
# -----------------------------------------------------------------------------
NOTION_OAUTH_CLIENT_ID=your_notion_client_id
NOTION_OAUTH_CLIENT_SECRET=your_notion_client_secret
NOTION_CALLBACK_URL=http://localhost:3000/api/oauth/notion/callback


# -----------------------------------------------------------------------------
# AIRTABLE (Integration node)
# -----------------------------------------------------------------------------
AIRTABLE_CLIENT_ID=your_airtable_client_id
AIRTABLE_CLIENT_SECRET=your_airtable_client_secret
AIRTABLE_CALLBACK_URL=http://localhost:3000/api/oauth/airtable/callback


# -----------------------------------------------------------------------------
# WEBHOOK SECURITY
# -----------------------------------------------------------------------------
WEBHOOK_SIGNATURE_HEADER=x-webhook-signature
WEBHOOK_TOLERANCE_SECONDS=300             # Reject requests older than 5 min


# -----------------------------------------------------------------------------
# CODE NODE SANDBOX (vm2)
# -----------------------------------------------------------------------------
CODE_NODE_TIMEOUT_MS=5000                 # Max execution time per code node
CODE_NODE_MEMORY_LIMIT_MB=64             # Memory cap per sandbox run


# -----------------------------------------------------------------------------
# OBSERVABILITY — SENTRY
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_ENVIRONMENT=development            # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1            # 10% of transactions traced


# -----------------------------------------------------------------------------
# OBSERVABILITY — PROMETHEUS METRICS
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090                         # Prometheus scrape port
METRICS_PATH=/metrics


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info                            # error | warn | info | debug
LOG_FORMAT=json                           # json | pretty (use pretty for local dev)
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/app.log


# -----------------------------------------------------------------------------
# EMAIL (Transactional — for auth emails, alerts)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_SECURE=false                         # true for port 465
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@yourplatform.com
EMAIL_FROM_NAME=Automation Platform


# -----------------------------------------------------------------------------
# SCHEDULER (Cron engine)
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC                    # Default timezone for schedule nodes
MAX_CONCURRENT_SCHEDULES=100


# -----------------------------------------------------------------------------
# EXECUTION ENGINE
# -----------------------------------------------------------------------------
MAX_WORKFLOW_DEPTH=50                     # Prevent infinite loop chains
EXECUTION_TIMEOUT_MS=300000              # 5 min max per full workflow run
MAX_CONCURRENT_EXECUTIONS=20            # Per user cap (enforce in middleware)
EXECUTION_LOG_RETENTION_DAYS=30         # Auto-purge old logs after N days


# -----------------------------------------------------------------------------
# STORAGE (for future file/attachment node support)
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local                      # local | s3
S3_BUCKET=your-bucket-name
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=your_aws_access_key
S3_SECRET_ACCESS_KEY=your_aws_secret_key
S3_ENDPOINT=                              # For S3-compatible stores (e.g. MinIO)


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_CODE_NODE_ENABLED=true
FEATURE_VERSIONS_ENABLED=true
FEATURE_METRICS_ENABLED=true
FEATURE_DEAD_LETTER_ENABLED=true
